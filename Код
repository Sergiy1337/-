def delete_book(books):
    """Удаляет книгу из списка по её порядковому номеру."""
    if not books:
        print("\nТрекер пуст, удалять нечего.")
        return books
        
    # Сначала показываем книги, чтобы юзер видел индексы
    show_all_books(books) 
    
    while True:
        choice = input("\nВведите номер книги для удаления (или '0' для отмены): ").strip()
        if choice == '0':
            return books
        try:
            idx = int(choice) - 1
            if 0 <= idx < len(books):
                removed = books.pop(idx)
                save_books(books)
                print(f"Книга «{removed['title']}» успешно удалена!")
                return books
            print("Ошибка: Книги с таким номером нет в списке.")
        except ValueError:
            print("Ошибка: Введите корректный номер.")


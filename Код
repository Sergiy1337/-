from datetime import datetime

def add_book(books):
    """Добавляет новую книгу в список с валидацией данных."""
    print("\n--- Добавление новой книги ---")
    author = input("Введите автора: ").strip()
    title = input("Введите название книги: ").strip()
    
    for book in books:
        if book['author'].lower() == author.lower() and book['title'].lower() == title.lower():
            print("Ошибка: Такая книга уже есть в трекере!")
            return books

    while True:
        try:
            score = int(input("Введите оценку (от 1 до 5): "))
            if 1 <= score <= 5:
                break
            print("Ошибка: Оценка должна быть в диапазоне от 1 до 5.")
        except ValueError:
            print("Ошибка: Введите целое число.")

    while True:
        date_str = input("Введите дату прочтения (ДД.ММ.ГГГГ): ").strip()
        try:
            datetime.strptime(date_str, "%d.%m.%Y")
            break
        except ValueError:
            print("Ошибка: Неверный формат даты. Используйте ДД.ММ.ГГГГ")

    new_book = {
        "author": author,
        "title": title,
        "score": score,
        "date": date_str
    }
    
    books.append(new_book)
    save_books(books)
    print(f"Книга «{title}» успешно добавлена!")
    return books

